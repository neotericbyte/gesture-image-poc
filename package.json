{
  "name": "@neotericbyte/gestro",
  "version": "1.0.0",
  "description": "Minimal gesture engine for image pan, zoom, rotate and export",
  "main": "dist/gestro.umd.js",
  "module": "dist/gestro.esm.js",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/gestro.esm.js",
      "require": "./dist/gestro.umd.js"
    }
  },
  "scripts": {
    "build:js": "esbuild src/gestro-image.js --bundle --format=esm --outfile=dist/gestro-image.esm.js",
    "build:example": "node scripts/build-example.mjs",
    "build": "npm run build:js && npm run build:example"
  },
  "types": "./types/index.d.ts",
  "files": [
    "dist",
    "types",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "gesture",
    "image",
    "zoom",
    "pan",
    "rotate",
    "touch",
    "pointer",
    "web-component"
  ],
  "author": "Neoteric Byte",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/neotericbyte/gestro.git"
  },
  "homepage": "https://github.com/neotericbyte/gestro#readme",
  "bugs": {
    "url": "https://github.com/neotericbyte/gestro/issues"
  },
  "devDependencies": {
    "esbuild": "^0.28.0"
  }
}